rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the requesting user exists in the admins collection
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── ADMINS ──────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      // Users can read their own admin document; admins can list all
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      // Only existing admins can write/delete or read all admin listings
      allow write: if isAdmin();
    }

    // ─── PRODUCTS ────────────────────────────────────────────────────────────
    match /products/{productId} {
      // Products are public catalog nodes, readable by all guests
      allow read: if true;
      // Only admins can modify products
      allow write: if isAdmin();
    }

    // ─── BANNERS ─────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── CATEGORIES ──────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── COUPONS ─────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      // Coupons must be readable by guests to validate them in the cart
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── ORDERS ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Users can place orders (create) and read their own orders
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Only admins can update status/delete orders
      allow update, delete: if isAdmin();
    }

    // ─── REVIEWS ─────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── SETTINGS ────────────────────────────────────────────────────────────
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
